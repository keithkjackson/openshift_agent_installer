{# Generated by Cursor — ImageSetConfiguration for oc-mirror plugin v2 (apiVersion mirror.openshift.io/v2alpha1) #}
kind: ImageSetConfiguration
apiVersion: mirror.openshift.io/v2alpha1
mirror:
  platform:
{% if oc_mirror_platform_graph | bool %}
    graph: true
{% endif %}
{% if oc_mirror_platform_architectures | default([]) | length > 0 %}
    architectures:
{% for arch in oc_mirror_platform_architectures %}
    - {{ arch }}
{% endfor %}
{% endif %}
    channels:
{% if oc_mirror_platform_channels | default([]) | length > 0 %}
{% for ch in oc_mirror_platform_channels %}
    - name: {{ ch.name }}
{% if ch.minVersion is defined and (ch.minVersion | string | length) > 0 %}
      minVersion: '{{ ch.minVersion }}'
{% endif %}
{% if ch.maxVersion is defined and (ch.maxVersion | string | length) > 0 %}
      maxVersion: '{{ ch.maxVersion }}'
{% endif %}
{% if ch.shortestPath is defined %}
      shortestPath: {{ ch.shortestPath | bool | lower }}
{% endif %}
      type: {{ ch.type | default('ocp') }}
{% endfor %}
{% else %}
    - name: {{ _oc_mirror_platform_channel_effective }}
      minVersion: '{{ ocp_version }}'
      maxVersion: '{{ ocp_version }}'
      shortestPath: true
      type: ocp
{% endif %}
{% if oc_mirror_operator_catalogs | default([]) | length > 0 %}
  operators:
{% for catalog_entry in oc_mirror_operator_catalogs %}
  - catalog: {{ catalog_entry.catalog }}
    packages:
{% for pkg in catalog_entry.packages %}
    - name: {{ pkg.name }}
{% if pkg.channels is defined and pkg.channels | length > 0 %}
      channels:
{% for c in pkg.channels %}
      - name: {{ c.name }}
{% if c.minVersion is defined and (c.minVersion | string | length) > 0 %}
        minVersion: '{{ c.minVersion }}'
{% endif %}
{% if c.maxVersion is defined and (c.maxVersion | string | length) > 0 %}
        maxVersion: '{{ c.maxVersion }}'
{% endif %}
{% endfor %}
{% endif %}
{% endfor %}
{% endfor %}
{% endif %}
